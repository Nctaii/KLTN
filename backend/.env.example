# Cổng chạy server
PORT=3000

# Kết nối PostgreSQL
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/interactive_novel

# JWT
JWT_ACCESS_SECRET=doi_thanh_chuoi_bi_mat_ngau_nhien_dai
JWT_REFRESH_SECRET=mot_chuoi_bi_mat_khac_cho_refresh_token
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7

# Claude (Anthropic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5

# Gmail SMTP (gửi OTP xác minh email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM=Tiểu Thuyết Tương Tác <your_email@gmail.com>
OTP_TTL_MINUTES=10
